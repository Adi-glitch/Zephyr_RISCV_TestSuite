diff --git a/arch/riscv/core/mmu.c b/arch/riscv/core/mmu.c
new file mode 100644
index 00000000000..dc982cb02ec
--- /dev/null
+++ b/arch/riscv/core/mmu.c
@@ -0,0 +1,273 @@
+/*
+ * Copyright (c) 2026 Zephyr bare-metal-suite port.
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+/*
+ * RISC-V Sv39 MMU support (CONFIG_RISCV_MMU).
+ *
+ * S-mode counterpart to PMP (which is M-mode only). At boot the kernel image
+ * and device MMIO are identity-mapped and paging is turned on (satp); the rest
+ * of RAM is left unmapped for the generic layer (k_mem_map()) to hand out.
+ * arch_mem_map()/arch_mem_unmap() create/destroy runtime mappings.
+ *
+ * Everything is identity-mapped at boot (KERNEL_VM_BASE == SRAM base), so a
+ * page table's physical address equals the (virtual) address we hold it at, and
+ * the page-table walker (which reads physical addresses) and our C pointers
+ * agree without any phys<->virt translation.
+ */
+
+#include <zephyr/kernel.h>
+#include <zephyr/arch/riscv/csr.h>
+#include <zephyr/sys/util.h>
+#include <zephyr/spinlock.h>
+#include <zephyr/linker/linker-defs.h>
+#include <zephyr/kernel/mm.h>
+#include <kernel_arch_func.h>
+#include <kernel_arch_interface.h>
+#include <stdint.h>
+
+/* Sv39 PTE bits (PTE_V/R/W/X/U/A/D, PTE_PPN_SHIFT) come from csr.h. */
+#define PTE_XWR       (PTE_R | PTE_W | PTE_X)
+
+#define SV39_LEVELS   3
+#define PT_ENTRIES    512
+#define PAGE_SHIFT    12
+#define PAGE_SIZE_4K  4096UL
+
+/*
+ * Static page-table pool. Each table is one 4 KB page (512 * 8 bytes). Page
+ * tables must be allocatable before the kernel heap exists (z_riscv_mmu_init
+ * runs in prep_c) and from under mmu_lock, so they come from here, never the
+ * heap -- mirroring arm64 (xlat_tables) and the bare-metal suite's pool.
+ */
+static uint64_t mmu_tables[CONFIG_RISCV_MMU_NUM_TABLES][PT_ENTRIES]
+	__aligned(PAGE_SIZE_4K);
+static bool mmu_table_used[CONFIG_RISCV_MMU_NUM_TABLES];
+static struct k_spinlock mmu_lock;
+static uint64_t *kernel_root;
+
+static uint64_t *alloc_table(void)
+{
+	for (int i = 0; i < CONFIG_RISCV_MMU_NUM_TABLES; i++) {
+		if (!mmu_table_used[i]) {
+			mmu_table_used[i] = true;
+			for (int j = 0; j < PT_ENTRIES; j++) {
+				mmu_tables[i][j] = 0;
+			}
+			return mmu_tables[i];
+		}
+	}
+
+	k_panic(); /* CONFIG_RISCV_MMU_NUM_TABLES too small */
+	return NULL;
+}
+
+/* VPN[level] index for va. level 2 = root, 1, 0 = leaf level. */
+static inline unsigned int vpn(uintptr_t va, int level)
+{
+	return (va >> (PAGE_SHIFT + 9 * level)) & (PT_ENTRIES - 1);
+}
+
+static inline uintptr_t pte_to_phys(uint64_t pte)
+{
+	return (uintptr_t)((pte >> PTE_PPN_SHIFT) << PAGE_SHIFT);
+}
+
+static inline uint64_t phys_to_ppn(uintptr_t pa)
+{
+	return ((uint64_t)(pa >> PAGE_SHIFT)) << PTE_PPN_SHIFT;
+}
+
+/* Map one 4 KB page va->pa with the given leaf permission bits (R/W/X/U). */
+static void map_page(uintptr_t va, uintptr_t pa, uint64_t perm)
+{
+	uint64_t *tbl = kernel_root;
+
+	for (int level = SV39_LEVELS - 1; level > 0; level--) {
+		uint64_t *pte = &tbl[vpn(va, level)];
+
+		if (!(*pte & PTE_V)) {
+			uint64_t *next = alloc_table();
+			/* non-leaf PTE: V set, R/W/X clear (pointer to next level) */
+			*pte = phys_to_ppn((uintptr_t)next) | PTE_V;
+		}
+		tbl = (uint64_t *)pte_to_phys(*pte);
+	}
+
+	tbl[vpn(va, 0)] = phys_to_ppn(pa) | perm | PTE_V | PTE_A | PTE_D;
+}
+
+/* Map a 1 GB gigapage (leaf at root level). va/pa must be 1 GB aligned. */
+static void map_gigapage(uintptr_t va, uintptr_t pa, uint64_t perm)
+{
+	kernel_root[vpn(va, 2)] = phys_to_ppn(pa) | perm | PTE_V | PTE_A | PTE_D;
+}
+
+/* Invalidate the leaf PTE covering va (handles a superpage leaf at any level). */
+static void unmap_page(uintptr_t va)
+{
+	uint64_t *tbl = kernel_root;
+
+	for (int level = SV39_LEVELS - 1; level > 0; level--) {
+		uint64_t *pte = &tbl[vpn(va, level)];
+
+		if (!(*pte & PTE_V)) {
+			return; /* already unmapped */
+		}
+		if (*pte & PTE_XWR) {
+			*pte = 0; /* superpage leaf at this level */
+			return;
+		}
+		tbl = (uint64_t *)pte_to_phys(*pte);
+	}
+
+	tbl[vpn(va, 0)] = 0;
+}
+
+static uint64_t perm_from_flags(uint32_t flags)
+{
+	uint64_t perm = PTE_R; /* mapped memory is always readable */
+
+	if (flags & K_MEM_PERM_RW) {
+		perm |= PTE_W;
+	}
+	if (flags & K_MEM_PERM_EXEC) {
+		perm |= PTE_X;
+	}
+	if (flags & K_MEM_PERM_USER) {
+		perm |= PTE_U;
+	}
+	return perm;
+}
+
+void arch_mem_map(void *virt, uintptr_t phys, size_t size, uint32_t flags)
+{
+	uintptr_t va = (uintptr_t)virt;
+	uint64_t perm = perm_from_flags(flags);
+	k_spinlock_key_t key = k_spin_lock(&mmu_lock);
+
+	for (size_t off = 0; off < size; off += PAGE_SIZE_4K) {
+		map_page(va + off, phys + off, perm);
+	}
+	__asm__ volatile("sfence.vma" ::: "memory");
+
+	k_spin_unlock(&mmu_lock, key);
+}
+
+void arch_mem_unmap(void *addr, size_t size)
+{
+	uintptr_t va = (uintptr_t)addr;
+	k_spinlock_key_t key = k_spin_lock(&mmu_lock);
+
+	for (size_t off = 0; off < size; off += PAGE_SIZE_4K) {
+		unmap_page(va + off);
+	}
+	__asm__ volatile("sfence.vma" ::: "memory");
+
+	k_spin_unlock(&mmu_lock, key);
+}
+
+/*
+ * Resumable page-fault hook. z_riscv_fault() (gated) offers a registered
+ * resolver a chance to fix the PTE for a page fault and signal "retry"; if
+ * none is registered (the default) the fault stays fatal exactly as before.
+ * Same control-flow slot as arm64's z_arm64_do_demand_paging and x86's
+ * z_x86_page_fault_handler; the resolver here is supplied by the caller rather
+ * than being the generic demand-paging resolver. Default-inert => production
+ * behavior is unchanged.
+ */
+static bool (*mmu_fault_fixup)(unsigned long scause, unsigned long stval);
+
+void z_riscv_mmu_set_fault_fixup(bool (*fn)(unsigned long scause,
+					    unsigned long stval))
+{
+	mmu_fault_fixup = fn;
+}
+
+bool z_riscv_mmu_try_fault_fixup(unsigned long scause, unsigned long stval)
+{
+	return mmu_fault_fixup != NULL && mmu_fault_fixup(scause, stval);
+}
+
+/*
+ * Raw-control companions to the portable API above. The K_MEM_PERM_* flags
+ * deliberately cannot express individual PTE bits (V-only games, A/D, U
+ * without the kernel's policy) or superpage levels; these two give tests and
+ * arch-aware code that control while the kernel stays in charge of the tables.
+ */
+
+uint64_t *z_riscv_mmu_pte_lookup(uintptr_t va)
+{
+	uint64_t *tbl = kernel_root;
+
+	for (int level = SV39_LEVELS - 1; level > 0; level--) {
+		uint64_t *pte = &tbl[vpn(va, level)];
+
+		if (!(*pte & PTE_V)) {
+			return NULL;
+		}
+		if (*pte & PTE_XWR) {
+			return pte; /* superpage leaf at this level */
+		}
+		tbl = (uint64_t *)pte_to_phys(*pte);
+	}
+
+	return &tbl[vpn(va, 0)];
+}
+
+void z_riscv_mmu_map_raw(uintptr_t va, uintptr_t pa, uint64_t pte_bits, int level)
+{
+	size_t leaf_span = 1UL << (PAGE_SHIFT + 9 * level);
+	uint64_t *tbl = kernel_root;
+	k_spinlock_key_t key;
+
+	__ASSERT(level >= 0 && level < SV39_LEVELS, "bad level %d", level);
+	__ASSERT((va % leaf_span) == 0, "va 0x%lx not aligned to level %d", va, level);
+	__ASSERT((pa % leaf_span) == 0, "pa 0x%lx not aligned to level %d", pa, level);
+
+	key = k_spin_lock(&mmu_lock);
+
+	for (int l = SV39_LEVELS - 1; l > level; l--) {
+		uint64_t *pte = &tbl[vpn(va, l)];
+
+		if (!(*pte & PTE_V)) {
+			uint64_t *next = alloc_table();
+
+			*pte = phys_to_ppn((uintptr_t)next) | PTE_V;
+		}
+		tbl = (uint64_t *)pte_to_phys(*pte);
+	}
+
+	/* exactly the caller's bits -- including, on purpose, V=0 if asked */
+	tbl[vpn(va, level)] = phys_to_ppn(pa) | pte_bits;
+	__asm__ volatile("sfence.vma" ::: "memory");
+
+	k_spin_unlock(&mmu_lock, key);
+}
+
+void z_riscv_mmu_init(void)
+{
+	kernel_root = alloc_table();
+
+	/* Device MMIO: identity-map the low 1 GB R/W (no execute) as a single
+	 * gigapage -- covers CLINT, PLIC, UART, the sifive_test finisher. */
+	map_gigapage(0x0UL, 0x0UL, PTE_R | PTE_W);
+
+	/* Kernel image: identity-map [z_mapped_start, z_mapped_end) R/W/X at 4 KB.
+	 * This is the only RAM mapped at boot; the rest stays unmapped so the
+	 * generic layer can allocate it for k_mem_map(). */
+	uintptr_t start = (uintptr_t)z_mapped_start;
+	uintptr_t end = (uintptr_t)z_mapped_end;
+
+	for (uintptr_t va = start; va < end; va += PAGE_SIZE_4K) {
+		map_page(va, va, PTE_R | PTE_W | PTE_X);
+	}
+
+	unsigned long satp_val = ((unsigned long)SATP_MODE_SV39 << 60) |
+				 ((uintptr_t)kernel_root >> PAGE_SHIFT);
+
+	csr_write(satp, satp_val);
+	__asm__ volatile("sfence.vma" ::: "memory");
+}
