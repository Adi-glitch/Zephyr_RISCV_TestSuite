diff --git a/arch/riscv/include/kernel_arch_func.h b/arch/riscv/include/kernel_arch_func.h
index c25f92d5fa8..bedf6374c2a 100644
--- a/arch/riscv/include/kernel_arch_func.h
+++ b/arch/riscv/include/kernel_arch_func.h
@@ -125,6 +125,33 @@ extern FUNC_NORETURN void z_riscv_switch_to_main_no_multithreading(
 
 #endif /* !CONFIG_MULTITHREADING */
 
+#ifdef CONFIG_RISCV_MMU
+/* Build the kernel's Sv39 page tables and turn on paging (write satp). Called
+ * from z_prep_c() on the primary hart before z_cstart(). */
+void z_riscv_mmu_init(void);
+
+/* Walk the live Sv39 tables and return a pointer to the leaf PTE covering va
+ * (including a superpage leaf at level 2/1), or NULL if an intermediate level
+ * is invalid. Tables are identity-mapped, so the pointer is dereferenceable;
+ * a caller that modifies bits must issue sfence.vma itself. */
+uint64_t *z_riscv_mmu_pte_lookup(uintptr_t va);
+
+/* Raw mapper (the bare-metal suite's pt_map_page equivalent): create
+ * intermediates as needed, then write the leaf at the given level (0 = 4 KB,
+ * 1 = 2 MB, 2 = 1 GB) as exactly ppn(pa) | pte_bits. The caller supplies ALL
+ * PTE bits (PTE_V/R/W/X/U/A/D from csr.h) -- V=0 entries are constructible on
+ * purpose. va/pa must be aligned to the level's span. */
+void z_riscv_mmu_map_raw(uintptr_t va, uintptr_t pa, uint64_t pte_bits, int level);
+
+/* Resumable page-fault hook. Register a resolver that, given a page fault's
+ * scause/stval, fixes the PTE and returns true to retry the faulting
+ * instruction (or false to let it stay fatal). z_riscv_fault() consults it for
+ * causes 12/13/15. Default NULL => faults remain fatal as before. */
+void z_riscv_mmu_set_fault_fixup(bool (*fn)(unsigned long scause,
+					    unsigned long stval));
